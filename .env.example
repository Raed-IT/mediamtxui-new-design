DATABASE_URL="file:./dev.db"
JWT_SECRET="change-this-secret"
MEDIAMTX_API_URL="http://127.0.0.1:9997"
NEXT_PUBLIC_WEBRTC_BASE_URL="http://127.0.0.1:8889"
# Used by recording and snapshot API. Install ffmpeg on the server.
FFMPEG_INPUT_TEMPLATE="rtsp://127.0.0.1:8554/{streamKey}"
MEDIAMTX_API_USER="admin"
MEDIAMTX_API_PASS="admin123"
# Optional fallback inputs for ffmpeg recording/snapshot. The API tries these in order.
# For authenticated RTSP, use for example:
# FFMPEG_INPUT_TEMPLATE="rtsp://admin:admin123@127.0.0.1:8554/{streamKey}"
FFMPEG_HLS_INPUT_TEMPLATE="http://127.0.0.1:8888/{streamKey}/index.m3u8"

# Server-side recording
# mediamtx = recommended: MediaMTX records on the server using its native recorder.
# ffmpeg = fallback: Next.js server spawns ffmpeg and saves mp4 under public/recordings.
SERVER_RECORDING_MODE="mediamtx"
MEDIAMTX_RECORD_PATH="./recordings/%path/%Y-%m-%d_%H-%M-%S-%f"
MEDIAMTX_RECORD_FORMAT="fmp4"

# If SERVER_RECORDING_MODE=ffmpeg or for snapshots, set server-readable stream URLs.
# If Next.js is inside Docker, DO NOT use 127.0.0.1 unless MediaMTX is in the same container.
MEDIAMTX_INTERNAL_HOST="127.0.0.1"
MEDIAMTX_RTSP_BASE_URL="rtsp://admin:admin123@127.0.0.1:8554"
MEDIAMTX_HLS_BASE_URL="http://127.0.0.1:8888"
MEDIAMTX_STREAM_USER="admin"
MEDIAMTX_STREAM_PASS="admin123"
